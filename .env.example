# Stripe Checkout metadata.product_key にテンプレート ID（例: hoshino-standard）を設定すると商品別メールに切替

# Stripe（https://dashboard.stripe.com）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
