# Supabase
VITE_SUPABASE_URL=https://vruxpxocefqxoxrwexhj.supabase.co
SUPABASE_URL=https://vruxpxocefqxoxrwexhj.supabase.co
# Dashboard → Settings → API → service_role（ローカル .env と Vercel の両方に必須）
SUPABASE_SERVICE_ROLE_KEY=

# 問い合わせフォーム通知（Gmail SMTP / Nodemailer）
GMAIL_USER=
GMAIL_APP_PASSWORD=

# メール通知（https://resend.com — Stripe 購入確認等で利用）
RESEND_API_KEY=
# ドメイン認証前のテストモード（1=有効・デフォルト, 0=本番）
RESEND_TEST_MODE=1
# テストモード時の送信元（Resend 未認証ドメインでは onboarding@resend.dev のみ可）
RESEND_TEST_FROM=KOISHIKAWA <onboarding@resend.dev>
# テストモード時の送信先（Resend アカウント認証済みメール）
RESEND_TEST_TO=bando.eiji.1177@gmail.com
# 本番モード (RESEND_TEST_MODE=0) 用
RESEND_FROM=KOISHIKAWA <onboarding@resend.dev>
NOTIFY_EMAIL=koishikawavibecoding@gmail.com
# DNS 認証後に購入確認メール送信を有効化（1=有効）+ purchase-email.js のコメント解除
RESEND_SEND_PURCHASE_EMAIL=0

# Stripe（https://dashboard.stripe.com）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
